
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'admin';
    }
    
    function isLinkedStudent() {
      return isSignedIn() && getUserData().linkedStudentId != null;
    }
    
    function getStudentDocId() {
      return getUserData().linkedStudentId;
    }

    // --- Collections ---

    // Users can read/write their own profile. Admins can read anyone's profile.
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId);
    }
    
    // Students can read their own linked student record. Admins can read/write all.
    match /students/{studentId} {
      allow create, write: if isAdmin();
      allow read: if isAdmin() || (isLinkedStudent() && studentId == getStudentDocId());
    }
    
    // Counter for student codes, only admin can read/write for the transaction.
    match /counters/studentCounter {
        allow read, write: if isAdmin();
    }
    
    // Lessons can be read by linked students if it's their lesson, or by any admin.
    // Write access is for admins only.
    match /lessons/{lessonId} {
        allow read: if isAdmin() || (isLinkedStudent() && resource.data.studentId == getStudentDocId());
        allow write: if isAdmin();
    }

    // Admins can read/write all announcements. All signed-in users can read published ones.
    match /announcements/{announcementId} {
        allow read: if isAdmin() || (isSignedIn() && resource.data.published == true);
        allow write: if isAdmin();
    }
    
    // Swap requests: created by linked students for their own lessons.
    // Read/write by admins. Students can read their own.
    match /swapRequests/{requestId} {
      allow create: if isLinkedStudent() && request.resource.data.studentId == getStudentDocId();
      allow read: if isAdmin() || (isLinkedStudent() && resource.data.studentId == getStudentDocId());
      allow update: if isAdmin(); // only admin can approve/reject
      allow delete: if isAdmin();
    }
    
    // App settings are read-only for clients, writable only by admin.
    match /settings/app {
        allow read: if isSignedIn();
        allow write: if isAdmin();
    }
    
    // Old posts rule, can be refined later if needed.
    match /users/{userId}/posts/{postId} {
        allow create, read, update, delete: if isOwner(userId);
    }
  }
}
