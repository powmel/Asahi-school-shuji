# Firebase Web SDK config.
# These NEXT_PUBLIC_* values are safe to expose to the browser and must also be set in Vercel.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK service account JSON.
# Set this only in local .env.local or Vercel Environment Variables.
# Do not commit the actual JSON value or a service-account file.
FIREBASE_SERVICE_ACCOUNT_KEY=
