{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User Profile",
      "type": "object",
      "description": "Represents a user's profile information.",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user, matching the Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "name": {
          "type": "string",
          "description": "The user's display name."
        },
        "role": {
            "type": "string",
            "description": "The user's role, either 'student' or 'admin'."
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the user profile was created.",
          "format": "date-time"
        }
      },
      "required": ["uid", "email", "name", "role", "createdAt"]
    },
    "Post": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Post",
      "type": "object",
      "description": "Represents a diary post of a student.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Post entity."
        },
        "studentId": {
          "type": "string",
          "description": "Reference to Student. (Relationship: Student 1:N Post)"
        },
        "content": {
          "type": "string",
          "description": "Content of the post"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp indicating when the post was created.",
          "format": "date-time"
        }
      },
      "required": ["id", "studentId", "content", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
      "collections": {
          "/users/{userId}": {
              "schema": {
                "$ref": "#/entities/UserProfile"
              },
              "description": "Stores user profile information. The document ID is the same as the Firebase Auth UID."
          },
          "/users/{userId}/posts/{postId}": {
              "schema": {
                  "$ref": "#/entities/Post"
              },
              "description": "Stores diary posts for each student. Only accessible by the owner (student) and admins."
          }
      }
  }
}
